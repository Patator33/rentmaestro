generator client {
  provider = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Apartment {
  id          String    @id @default(uuid())
  name        String?
  address     String
  complement  String?
  city        String
  zipCode     String
  rent        Float
  charges     Float
  description String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  comment     String?
  mortgageAmount Float?
  leases      Lease[]
  expenses    Expense[]
}

model Tenant {
  id           String           @id @default(uuid())
  firstName    String
  lastName     String
  email        String           @unique
  phone        String?
  coTenantFirstName String?
  coTenantLastName  String?
  coTenantEmail     String?
  coTenantPhone     String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  paymentDay   Int?             @default(5)
  leases       Lease[]
  documents    TenantDocument[]
  notes        TenantNote[]
}

model TenantDocument {
  id        String   @id @default(uuid())
  name      String
  url       String
  type      String
  size      Int
  createdAt DateTime @default(now())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantNote {
  id        String   @id @default(uuid())
  content   String
  type      String   @default("NOTE") // NOTE, CALL, EMAIL, LETTER, REMINDER
  createdAt DateTime @default(now())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Lease {
  id            String        @id @default(uuid())
  apartmentId   String
  tenantId      String
  startDate     DateTime
  endDate       DateTime?
  rentAmount    Float
  chargesAmount Float
  depositAmount Float?
  depositStatus String?       // PENDING, RECEIVED, TO_RETURN, RETURNED, DEDUCTED
  depositReturnedAt DateTime?
  isActive      Boolean       @default(true)
  lastRentReviewDate DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  apartment     Apartment     @relation(fields: [apartmentId], references: [id])
  tenant        Tenant        @relation(fields: [tenantId], references: [id])
  payments      RentPayment[]
}

model RentPayment {
  id        String   @id @default(uuid())
  leaseId   String
  period    DateTime
  amount    Float
  status    String   // PAID, PENDING, LATE
  paidAt    DateTime?
  sentAt    DateTime?
  createdAt DateTime @default(now())
  lease     Lease    @relation(fields: [leaseId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String    @id @default(uuid())
  apartmentId String
  category    String    // TAX, INSURANCE, MAINTENANCE, MANAGEMENT, OTHER
  description String
  amount      Float
  date        DateTime
  recurring   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
}
