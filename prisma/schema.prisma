generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Apartment {
  id              String    @id @default(uuid())
  name            String?
  address         String
  complement      String?
  city            String
  zipCode         String
  rent            Float
  charges         Float
  description     String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  comment         String?
  mortgageAmount  Float?
  insuranceAmount Float?
  taxAmount       Float?
  companyId       String?
  company         Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  leases          Lease[]
  expenses        Expense[]
  tasks           Task[]
  documents       ApartmentDocument[]
}

model Tenant {
  id                String           @id @default(uuid())
  firstName         String
  lastName          String
  email             String           @unique
  phone             String?
  coTenantFirstName String?
  coTenantLastName  String?
  coTenantEmail     String?
  coTenantPhone     String?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  paymentDay        Int?             @default(5)
  portalToken       String?          @unique
  leases            Lease[]
  documents         TenantDocument[]
  notes             TenantNote[]
  tasks             Task[]
}

model TenantDocument {
  id        String   @id @default(uuid())
  name      String
  url       String
  type      String
  size      Int
  createdAt DateTime @default(now())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model TenantNote {
  id        String   @id @default(uuid())
  content   String
  type      String   @default("NOTE") // NOTE, CALL, EMAIL, LETTER, REMINDER
  createdAt DateTime @default(now())
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

model Lease {
  id                 String        @id @default(uuid())
  apartmentId        String
  tenantId           String
  startDate          DateTime
  endDate            DateTime?
  rentAmount         Float
  chargesAmount      Float
  depositAmount      Float?
  depositStatus      String? // PENDING, RECEIVED, TO_RETURN, RETURNED, DEDUCTED
  depositReturnedAt  DateTime?
  isActive           Boolean       @default(true)
  lastRentReviewDate DateTime?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  apartment          Apartment     @relation(fields: [apartmentId], references: [id])
  tenant             Tenant        @relation(fields: [tenantId], references: [id])
  payments           RentPayment[]
}

model RentPayment {
  id              String    @id @default(uuid())
  leaseId         String
  period          DateTime
  amount          Float
  status          String // PAID, PENDING, LATE
  paidAt          DateTime?
  sentAt          DateTime? // Used for LATE/PENDING reminders
  receiptSentAt   DateTime? // Used for PAID receipts
  createdAt       DateTime  @default(now())
  lease           Lease     @relation(fields: [leaseId], references: [id], onDelete: Cascade)
}

model Expense {
  id          String    @id @default(uuid())
  apartmentId String
  category    String // TAX, INSURANCE, MAINTENANCE, MANAGEMENT, OTHER
  description String
  amount      Float
  date        DateTime
  recurring   Boolean   @default(false)
  createdAt   DateTime  @default(now())
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
}

model Task {
  id          String     @id @default(cuid())
  apartmentId String
  apartment   Apartment  @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  title       String
  description String?
  status      String     @default("TODO") // TODO, IN_PROGRESS, DONE
  cost        Float?
  dueDate     DateTime?
  tenantId    String?
  tenant      Tenant?    @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model ApartmentDocument {
  id          String    @id @default(uuid())
  apartmentId String
  name        String
  url         String
  type        String
  size        Int
  createdAt   DateTime  @default(now())
  apartment   Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
}

model Company {
  id          String      @id @default(uuid())
  name        String
  type        String      // SCI, LMNP, NOM_PROPRE, etc.
  siret       String?
  address     String?
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  apartments  Apartment[]
}

model Contact {
  id          String     @id @default(uuid())
  name        String
  role        String     // ARTISAN, SYNDIC, INSURANCE, OTHER
  email       String?
  phone       String?
  address     String?
  comment     String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  apartmentId String?
  apartment   Apartment? @relation(fields: [apartmentId], references: [id], onDelete: SetNull)
}
